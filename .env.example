# Firebase Service Account
# Sæt indholdet af din service account JSON her som én linje
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Alternativt: sti til JSON-filen (kun lokalt)
# GOOGLE_APPLICATION_CREDENTIALS=./echolima-firebase-adminsdk.json

# Din Firebase Admin email (bruges til isAdmin check)
ADMIN_EMAIL=per.fisker@gmail.com

# Port (Railway sætter denne automatisk)
PORT=3000
